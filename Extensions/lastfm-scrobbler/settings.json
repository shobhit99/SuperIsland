        },
        {
          "type": "button",
          "key": "retryQueue",
          "label": "Retry queued scrobbles"
        },
        {
          "type": "button",
          "key": "signOut",
          "label": "Sign out of Last.fm"
        },
        {
          "type": "button",
          "key": "openApiAccounts",
          "label": "Open Last.fm API keys page"
        },
        {
          "type": "button",
          "key": "openDesktopAuthDocs",
          "label": "Open Last.fm desktop auth docs"
        }
      ]
    }
  ]
