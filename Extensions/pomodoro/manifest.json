{
  "id": "com.workview.pomodoro",
  "name": "Pomodoro Timer",
  "version": "1.0.0",
  "minAppVersion": "1.0.0",
  "main": "index.js",
  "author": {
    "name": "Workview"
  },
  "description": "Focus timer with compact countdown and quick controls.",
  "license": "MIT",
  "categories": ["productivity", "timer"],
  "permissions": ["notifications", "storage"],
  "capabilities": {
    "compact": true,
    "expanded": true,
    "fullExpanded": true,
    "minimalCompact": true,
    "backgroundRefresh": true,
    "settings": true
  },
  "refreshInterval": 1.0,
  "activationTriggers": ["manual", "timer"]
}
